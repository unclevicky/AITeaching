# ── MiniMax Speech-01 Configuration ──
# API endpoint: https://api.minimaxi.com (HTTP REST, not WebSocket S2S)
# T2A: POST /v1/t2a_pro
# Chat: POST /v1/chat/completions
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_URL=https://api.minimaxi.com
MINIMAX_MODEL=MiniMax-M2.7

# ── 百度语音识别配置 ──
# 申请地址: https://console.bce.baidu.com/qianfan/ais/console/applicationConsole/application
# 创建应用后获取 API Key 和 Secret Key
BAIDU_SPEECH_API_KEY=your_baidu_api_key_here
BAIDU_SPEECH_SECRET_KEY=your_baidu_secret_key_here
# 语种设置: 1537=中文普通话, 15372=中英文混合, 1737=英语, 1637=粤语
BAIDU_SPEECH_DEV_PID=1537
# 采样率: 16000 或 8000 (前端会重采样到 8000Hz)
BAIDU_SPEECH_SAMPLE_RATE=8000

# ── Server Configuration ──
SERVER_PORT=3003
